#!/bin/bash

set -exu

test $# = 0

mkdir -p /run/user/$UID/flashmq.d

cat > /run/user/$UID/flashmq.conf <<_
max_packet_size 10240
client_max_write_buffer_size 1048576

plugin /usr/libexec/flashmq/libflashmq-dbus-plugin.so
thread_count 1

expire_sessions_after_seconds 86400
include_dir /run/user/${UID}/flashmq.d
log_level notice
retained_messages_mode enabled

listen {
  protocol mqtt
  port 1883
}

listen {
  protocol websockets
  port 9001
}
_

if nc -v -q 0 192.168.42.254 1883 </dev/null ; then
    id="$(cat /data/conf/unique-id)"
    test -n "$id"
    cat > /run/user/$UID/flashmq.d/bridge.conf <<_
bridge {
    protocol_version mqtt5
    bridge_protocol_bit true

    address 192.168.42.254

    publish S/$id/# 1
    publish N/$id/# 1
    subscribe R/$id/# 1
    subscribe W/$id/# 1
    publish   I/$id/out/#
    subscribe I/$id/in/#
}
_
fi
